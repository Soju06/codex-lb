CODEX_LB_DATA_DIR=/var/lib/codex-lb
CODEX_LB_DASHBOARD_AUTH_MODE=trusted_header
CODEX_LB_FIREWALL_TRUST_PROXY_HEADERS=true
CODEX_LB_FIREWALL_TRUSTED_PROXY_CIDRS=127.0.0.1/32
CODEX_LB_DASHBOARD_AUTH_PROXY_HEADER=Remote-User
CODEX_LB_DASHBOARD_ACCESS_JWT_REQUIRED=true
CODEX_LB_DASHBOARD_ACCESS_JWT_ISSUER=https://onda.cloudflareaccess.com
CODEX_LB_DASHBOARD_ACCESS_JWT_AUDIENCES=REPLACE_WITH_EXACT_ACCESS_AUD
CODEX_LB_DASHBOARD_ACCESS_ALLOWED_EMAIL_DOMAINS=onda.lol

CODEX_LB_REQUEST_LOG_RETENTION_DAYS=30
CODEX_LB_REQUEST_LOG_CLEANUP_INTERVAL_SECONDS=3600
CODEX_LB_REQUEST_LOG_STORE_ERROR_DETAILS=false
CODEX_LB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_ENABLED=true
CODEX_LB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_MAX_FILES=5
CODEX_LB_DATABASE_SQLITE_PRE_MIGRATE_BACKUP_MAX_AGE_DAYS=30

CODEX_LB_CONVERSATION_ARCHIVE_ENABLED=false
CODEX_LB_LOG_PROXY_REQUEST_PAYLOAD=false
CODEX_LB_LOG_UPSTREAM_REQUEST_PAYLOAD=false
CODEX_LB_LOG_PROXY_REQUEST_SHAPE_RAW_CACHE_KEY=false

CODEX_LB_USAGE_REFRESH_ENABLED=true
CODEX_LB_USAGE_REFRESH_INTERVAL_SECONDS=60
CODEX_LB_METRICS_ENABLED=false
CODEX_LB_LOG_FORMAT=json
